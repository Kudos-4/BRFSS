# ============================================================
# BRFSS repo — what stays OUT of Git
# ============================================================
# Rule of thumb: raw source dumps and anything regenerable by
# re-running the pipeline. Small cleaned/recoded parquets, plots,
# and summary CSVs ARE committed so the Colab notebooks run
# immediately after a clone.

# --- Python / IDE / env ---
.venv/
venv/
env/
.idea/
.vscode/
.claude/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- Huge raw source (1.1 GB pickle; the 35 MB parquet is kept) ---
BRFSS_2024.pkl

# --- Giant per-row missing-value dumps (~400 MB each, regenerable) ---
# Match any numbered prefix, e.g. 09_Rows_With_Missing_Values.csv, case-insensitive.
*Rows_With_Missing_Values.csv
*rows_with_missing_values.csv

# --- Large intermediate CSVs (the parquet twins are kept instead) ---
BRFSS_Cleaned/BRFSS_2024_cleaned.csv
BRFSS_Cleaned/BRFSS_2024_recoded.csv

# --- Large trained model blob (62 MB, regenerated by BRFSS_Model.py) ---
BRFSS_Models/Random_Forest.pkl

# --- OS cruft ---
.DS_Store
Thumbs.db
